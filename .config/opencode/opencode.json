{
  "$schema": "https://opencode.ai/config.json",
  "model": "ollama/qwen3.5:cloud",
	"default_agent": "plan",
  "provider": {
    "ollama": {
      "models": {
        "minimax-m2.7:cloud": {
          "_launch": true,
          "limit": {
            "context": 204800,
            "output": 128000
          },
          "name": "minimax-m2.7:cloud"
        },
        "qwen3.5:cloud": {
          "_launch": true,
          "limit": {
            "context": 262144,
            "output": 32768
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "name": "qwen3.5:cloud"
        }
      },
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      }
    }
  }
}
