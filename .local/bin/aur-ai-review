#!/bin/bash

# Se paru passa i file come argomenti, li leggiamo, altrimenti leggiamo dallo stdin
if [ -n "$1" ] && [ -f "$1" ]; then
	CONTENT=$(cat "$1")
	FILE_NAME=$(basename "$1")
else
	# Se viene passato tramite stdin (comportamento tipico di molti pager)
	CONTENT=$(cat)
	FILE_NAME="PKGBUILD/Diff"
fi

# Se non c'è contenuto, esci senza errori
if [ -z "$CONTENT" ]; then
	exit 0
fi

echo -e "\n=== [AI REVIEW] Analisi di $FILE_NAME ==="

# Prepariamo il prompt includendo il contenuto del file
PROMPT="You are an expert SOC security analyst specializing in Arch Linux packaging.
Your only task is to inspect PKGBUILD files (or diffs of them) for indicators of
compromise (IoCs) or highly suspicious behavior. You are not reviewing code style
or packaging conventions — only security.

Check strictly for these violations:

1. HIDDEN NETWORK REQUESTS: Downloading files (via curl, wget, git clone, nc, or similar)
   inside the build(), prepare(), package(), or any pkgver()/*_check() function is forbidden.
   All downloads MUST go exclusively through the official source=() array, so they are
   verified against the checksum arrays (sha256sums=, b2sums=, etc.). Flag any network
   command found inside a function body as DANGER.
2. MASQUERADING / OBFUSCATION: Look for files with innocuous extensions
   (.dat, .png, .txt, .conf, etc.) that are actually executed through an interpreter
   (sh, bash, python, perl, eval, source). This is a clear disguise attempt. Also flag
   base64/hex-encoded blobs that get decoded and executed, and unusually long or randomized
   variable/function names meant to hide intent.
3. SUSPICIOUS DOMAINS: Check every URL in source=() and anywhere else in the file. Flag URLs
   that don't match the project's official upstream domain, as well as pastebin-style services
   (pastebin.com, ptpb.ch, gist, ix.io, termbin), URL shorteners (bit.ly, tinyurl, t.co), raw
   IP addresses, or newly-registered-looking domains.
4. SILENT BACKGROUND EXECUTION: Trailing '&' (or nohup/disown/setsid) used to launch a process
   in the background without the user noticing is a common backdoor/infostealer pattern — flag it.
5. PRIVILEGE / PERSISTENCE ABUSE: Flag any use of sudo/su, writes outside $srcdir/$pkgdir
   (e.g. to $HOME, /etc, systemd unit/timer directories, shell rc files, cron), or code that
   modifies .bashrc/.profile/.zshrc/.bash_profile — these indicate an attempt to gain persistence
   or escalate privileges beyond what packaging requires.
6. EXFILTRATION: Flag any command that reads sensitive files (SSH keys, GPG keys,
   browser profiles, environment variables, /etc/passwd or /etc/shadow) and sends them anywhere
   over the network.

Analyze the following content. If it violates ANY of the rules above, list each specific
violation, quote the offending line(s), and explain the concrete risk.
If it is clean on every rule, respond with EXACTLY: SAFE — and nothing else.

Content to analyze:
$CONTENT"

# RESPONSE=$(echo "$PROMPT" | agy)
RESPONSE=$(echo "$PROMPT" | aichat)

# Il modello espone il suo ragionamento tra tag <think>...</think>: lo scartiamo,
# ci interessa solo la risposta finale (SAFE/violazioni).
RESPONSE=$(sed '/<think>/,/<\/think>/d' <<<"$RESPONSE")

echo "$RESPONSE"
echo "--------------------------------------------------"
